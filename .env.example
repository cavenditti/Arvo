# Copy to .env at repo root. The backend loads it via dotenvy.
DATABASE_URL=postgres://arvo:arvo@localhost:5439/arvo
# Release builds refuse to start unless this is set to >= 32 chars (generate: openssl rand -hex 32).
# Debug builds fall back to an insecure dev default with a warning.
JWT_SECRET=dev-secret-change-me
PORT=8787
UPLOAD_DIR=./var/uploads
RUST_LOG=info,arvo_api=debug,tower_http=info

# --- Optional ---------------------------------------------------------------
# Comma-separated list of allowed CORS origins for production deployments
# (e.g. https://app.example.com). Unset = permissive (dev default).
# ALLOWED_ORIGINS=
# Max sqlx pool connections (default 10).
# DATABASE_MAX_CONNECTIONS=10
# Raster tile cache directory, imagery builds only (default ./var/tiles).
# TILE_CACHE_DIR=./var/tiles
# Docker compose overrides (defaults shown; DATABASE_URL must match if changed).
# ARVO_DB_PORT=5439
# ARVO_DB_USER=arvo
# ARVO_DB_PASSWORD=arvo
# ARVO_DB_NAME=arvo

# --- Plant tier, Phase P (all optional) --------------------------------------
# Nothing below is needed for `make db-up migrate api app`. The compose services are
# behind profiles; the make targets source this file before calling compose, because
# compose itself only reads a `.env` sitting next to infra/docker-compose.yml.
#
# Object store for captures (raw photos, ortho.tif, dsm.tif). Resolved by the API and
# the worker from backend/, so the default is backend/var/store (git-ignored).
# STORE_DIR=./var/store
#
# Plant detector service (services/plant-detect), started with `make detect-up`. When set, the
# worker's `detect` stage POSTs to it — that path also covers vine/row_segment and needs no GDAL
# in the worker. Unset, unreachable or erroring => the worker falls back to its in-process CV
# path, so this is always optional (docs/API-PLANT.md §Detection).
# PLANT_DETECT_URL=http://127.0.0.1:8788
# Host port for the service. Published on 127.0.0.1 only: it has no authentication.
# PLANT_DETECT_PORT=8788
# uvicorn workers (one per core; each request is CPU-bound).
# PLANT_DETECT_WORKERS=2
# Let the service read absolute paths instead of store keys only. Leave off.
# PLANT_DETECT_ALLOW_ABS_PATHS=0
# Request timeout the worker allows one detection call, seconds (default 600). Crown
# delineation over tens of millions of pixels is slow; too low silently forces the fallback.
# PLANT_DETECT_TIMEOUT_S=600
#
# OpenDroneMap, used by the worker's `sfm` stage. It shells out to
# `docker run --rm <ODM_IMAGE>` itself; `make odm-pull` pre-fetches the image. Under
# colima only paths inside $HOME are visible to that container.
# ODM_IMAGE=opendronemap/odm:latest
# ODM_DOCKER=docker
# Bypass docker entirely: a host ODM install or a CI stub speaking ODM's CLI.
# ODM_COMMAND=
# Extra ODM flags, whitespace-separated (e.g. --fast-orthophoto --pc-quality low).
# ODM_EXTRA_ARGS=
# Wall-clock budget for one ODM run, seconds (default 4 h).
# ODM_TIMEOUT_SECS=14400
#
# Worker poll interval, seconds — `make worker` passes it as --interval-secs.
# WORKER_INTERVAL=5
