# Copy to .env at repo root. The backend loads it via dotenvy.
DATABASE_URL=postgres://arvo:arvo@localhost:5439/arvo
# Release builds refuse to start unless this is set to >= 32 chars (generate: openssl rand -hex 32).
# Debug builds fall back to an insecure dev default with a warning.
JWT_SECRET=dev-secret-change-me
PORT=8787
UPLOAD_DIR=./var/uploads
RUST_LOG=info,arvo_api=debug,tower_http=info

# --- Optional ---------------------------------------------------------------
# Comma-separated list of allowed CORS origins for production deployments
# (e.g. https://app.example.com). Unset = permissive (dev default).
# ALLOWED_ORIGINS=
# Max sqlx pool connections (default 10).
# DATABASE_MAX_CONNECTIONS=10
# Raster tile cache directory, imagery builds only (default ./var/tiles).
# TILE_CACHE_DIR=./var/tiles
# Docker compose overrides (defaults shown; DATABASE_URL must match if changed).
# ARVO_DB_PORT=5439
# ARVO_DB_USER=arvo
# ARVO_DB_PASSWORD=arvo
# ARVO_DB_NAME=arvo
